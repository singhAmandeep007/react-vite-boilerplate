{
  "name": "vite-react-boilerplate",
  "author": {
    "name": "Amandeep Singh",
    "email": "amandeep.singh.fsd@gmail.com"
  },
  "description": "A production ready, batteries included starter template for Vite + React projects",
  "keywords": [
    "vite",
    "react",
    "boilerplate",
    "starter",
    "template"
  ],
  "repository": {
    "type": "git"
  },
  "license": "MIT",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "preview:local:msw": "npm run build && vite preview --port 5101",
    "dev:test": "start-server-and-test dev http://localhost:9001",
    "init:msw": "msw init ./public --no-save",
    "lint": "eslint --report-unused-disable-directives --max-warnings 5 \"{src,cypress}/**/*.{js,jsx,ts,tsx}\"",
    "format": "prettier --write \"{src,cypress}/**/*.{js,jsx,ts,tsx,css,scss,html,md,json}\"",
    "tsc:check": "tsc --build --noEmit ",
    "tsc:watch": "tsc --build --noEmit --watch",
    "TEST-START": "--------------------------------------------------------------------------",
    "test": "run-s test:unit",
    "test:unit": "vitest run --project=unit",
    "test:unit:coverage": "vitest run --project=unit --coverage",
    "test:unit:watch": "vitest --project=unit",
    "test:unit:ui": "vitest --project=unit --ui --coverage.enabled=true",
    "test:storybook": "vitest run --project=storybook",
    "test:e2e": "npm run dev:test 'cypress open'",
    "test:e2e:headless": "npm run dev:test 'cypress run'",
    "cy:install": "cypress install",
    "TEST-END": "----------------------------------------------------------------------------",
    "COMMIT-START": "------------------------------------------------------------------------",
    "commit:pre": "lint-staged",
    "commit": "git-cz",
    "commit:devmoji": "devmoji -e --lint",
    "COMMIT-END": "--------------------------------------------------------------------------",
    "prepare": "git init && husky || true",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@tanstack/react-query": "^5.96.1",
    "@tanstack/react-router": "^1.168.10",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "ky": "^1.14.3",
    "lucide-react": "^1.7.0",
    "radash": "^12.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-i18next": "^17.0.2",
    "react-responsive": "^10.0.0",
    "superjson": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7",
    "@chromatic-com/storybook": "^5.1.1",
    "@eslint/js": "^9.39.4",
    "@faker-js/faker": "^10.4.0",
    "@hookform/devtools": "^4.4.0",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-links": "^10.3.3",
    "@storybook/addon-themes": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/react": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@tanstack/react-query-devtools": "^5.96.1",
    "@tanstack/router-devtools": "^1.166.11",
    "@tanstack/router-plugin": "^1.167.12",
    "@testing-library/cypress": "^10.1.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "autoprefixer": "^10.4.20",
    "browserslist": "^4.28.2",
    "browserslist-to-esbuild": "^2.1.1",
    "commitizen": "^4.3.1",
    "cypress": "^15.13.0",
    "cypress-vite": "^1.8.0",
    "cz-conventional-changelog": "^3.3.0",
    "devmoji": "^2.3.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.39.4",
    "eslint-plugin-cypress": "^6.2.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.3",
    "eslint-plugin-testing-library": "^7.15.4",
    "globals": "^17.4.0",
    "husky": "^9.1.6",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.10",
    "msw": "^2.12.14",
    "msw-storybook-addon": "^2.0.6",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.59.1",
    "postcss": "^8.4.47",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rollup-plugin-visualizer": "^5.12.0",
    "start-server-and-test": "^3.0.0",
    "storybook": "^10.3.3",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.14",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "undici": "^7.24.6",
    "vite": "^7.3.1",
    "vite-plugin-checker": "^0.12.0",
    "vite-plugin-inspect": "^11.3.3",
    "vite-plugin-svgr": "^5.0.0",
    "vitest": "^4.1.2"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
